# =============================================================================
# rally_tracker — Deployment-Konfiguration
#
# Diese Datei nach .env kopieren und anpassen:
#   cp .env.example .env
#
# .env wird NICHT ins Git eingecheckt (siehe .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Hardware / Gerätepfade
# -----------------------------------------------------------------------------

# Serieller Port für VISCA-Kamera
RT_VISCA_PORT=/dev/ttyUSB0

# V4L2-Videogerät (HDMI-RX)
# Mit 'v4l2-ctl --list-devices' ermitteln
RT_CAPTURE_DEVICE=/dev/video0

# GIDs für Device-Zugriff (mit 'stat -c "%g" /dev/ttyUSB0' etc. prüfen)
RT_GID_DIALOUT=20
RT_GID_VIDEO=44
RT_GID_RENDER=104

# Pfad zum Rockchip BSP GStreamer-Plugin-Verzeichnis auf dem Host
# Enthält: libgstrkmpp.so (mpph264enc Element)
RT_GST_PLUGIN_HOST_PATH=/usr/lib/aarch64-linux-gnu/gstreamer-1.0

# -----------------------------------------------------------------------------
# Video-Quelle
# -----------------------------------------------------------------------------
RT_CAPTURE_WIDTH=1920
RT_CAPTURE_HEIGHT=1080

# -----------------------------------------------------------------------------
# Detektion
# -----------------------------------------------------------------------------
# Modus: vehicles | faces
RT_DETECTOR_MODE=faces

# Modellname (relativ zu /app oder /app/models)
# RKNN-Modell wird bevorzugt wenn vorhanden, sonst CPU-Fallback (.pt)
RT_DETECTOR_MODEL=yolov8n-face-320.rknn

RT_DETECTOR_CONFIDENCE=0.45
RT_DETECTOR_IOU=0.45
RT_DETECTOR_MAX_LOST_FRAMES=60

# -----------------------------------------------------------------------------
# PTZ Tracker
# -----------------------------------------------------------------------------
RT_TRACKER_PAN_GAIN=36.0
RT_TRACKER_TILT_GAIN=22.0
RT_TRACKER_DEAD_ZONE=0.05
RT_TRACKER_PAN_SPEED_MAX=18
RT_TRACKER_TILT_SPEED_MAX=12
RT_TRACKER_EMA_ALPHA=0.5
RT_TRACKER_GAIN_ADAPT_RATE=0.15
RT_TRACKER_GAIN_RECOVER_RATE=0.003
RT_TRACKER_GAIN_MIN_FACTOR=0.3
RT_TRACKER_RETURN_DELAY=1.5
RT_TRACKER_RETURN_TRAVEL_TIME=4.0
RT_TRACKER_HOME_PRESET=0
RT_TRACKER_CMD_INTERVAL=0.05

# -----------------------------------------------------------------------------
# UDP-Stream
# -----------------------------------------------------------------------------
RT_STREAM_ENABLED=true
RT_STREAM_HOST=172.18.5.24
RT_STREAM_PORT=4441
RT_STREAM_QP=18
RT_STREAM_FPS=50
RT_STREAM_TTL=64
# ALSA-Gerät für Audio (leer = kein Audio)
RT_STREAM_AUDIO_DEVICE=hw:5,0
RT_STREAM_AUDIO_BITRATE=128000

# -----------------------------------------------------------------------------
# REST API
# -----------------------------------------------------------------------------
RT_API_ENABLED=true
RT_API_HOST=0.0.0.0
RT_API_PORT=8080

# -----------------------------------------------------------------------------
# MQTT
# -----------------------------------------------------------------------------
RT_MQTT_ENABLED=false
RT_MQTT_HOST=127.0.0.1
RT_MQTT_PORT=1883
RT_MQTT_USERNAME=
RT_MQTT_PASSWORD=
RT_MQTT_CLIENT_ID=
RT_MQTT_TOPIC_PREFIX=rally_tracker
RT_MQTT_QOS=1
RT_MQTT_STATUS_INTERVAL=5.0
# TLS: Pfad zur CA-Datei (leer = kein TLS)
RT_MQTT_TLS_CAFILE=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
RT_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Pfade (innerhalb des Containers)
# -----------------------------------------------------------------------------
RT_MODELS_PATH=./models
RT_LOG_PATH=./logs
